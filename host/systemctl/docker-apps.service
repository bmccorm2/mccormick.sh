[Unit]
Description=Docker Compose Privacy Service
Requires=docker.service docker-infrastructure.service
After=docker.service docker-infrastructure.service

[Service]
Environment="ENV=prd"
Type=oneshot
RemainAfterExit=yes
User=root
WorkingDirectory=/opt/docker/apps
ExecStart=/usr/bin/docker compose pull ; docker compose up --build -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target